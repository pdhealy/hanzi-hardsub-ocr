{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit|Read|Glob|Grep|Agent|Task|WebFetch|WebSearch|NotebookEdit|TodoWrite|TodoRead",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /workspace/docs/commands && jq -r '\"[\" + (now | strftime(\"%Y-%m-%d %H:%M:%S\")) + \"] \" + .tool_name + \" | \" + (if .tool_input.command then .tool_input.command elif .tool_input.file_path then .tool_input.file_path elif .tool_input.pattern then (\"pattern=\" + .tool_input.pattern) else (.tool_input | tojson | .[0:200]) end)' >> /workspace/docs/commands/command.log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
